{
  "schemaVersion": 1,
  "addon": {
    "id": "ezogroupframes",
    "name": "EZOGroupFrames",
    "version": "0.1.9",
    "stage": "beta",
    "status": "beta",
    "phase": "public-beta",
    "visibility": "public",
    "manifest": "EZOGroupFrames.txt",
    "package": {
      "rootFolderName": "EZOGroupFrames",
      "zipName": "EZOGroupFrames_v0.1.9.zip",
      "outputPath": "dist",
      "include": [
        "*.txt",
        "*.lua",
        "*.xml",
        "modules/**",
        "lang/**",
        "media/**",
        "textures/**",
        "fonts/**",
        "bindings/**"
      ],
      "exclude": [
        ".codex/**",
        ".agents/**",
        ".cursor/**",
        ".github/**",
        ".git/**",
        ".vscode/**",
        "dev/**",
        "docs/**",
        "scripts/**",
        "tests/**",
        "test/**",
        "node_modules/**",
        "build/**",
        "dist/**",
        "local/**",
        "private/**",
        "scratch/**",
        "tmp/**",
        "temp/**",
        "AGENTS.md",
        "docs/CODEX_HANDOFF.md",
        "*.md",
        "*.ps1",
        "*.sh",
        "*.log",
        ".env*",
        "*.secret*",
        "secrets.*",
        "*.local*",
        "*.tmp",
        "*.temp",
        "*.bak",
        "*.backup",
        "*.old",
        "*.orig"
      ]
    }
  },
  "discord": {
    "webhookSecretNames": {
      "downloads": "EZO_CODEX_DOWNLOADS",
      "releases": "EZO_CODEX_RELEASES",
      "status": "EZO_CODEX_STATUS",
      "announcements": "EZO_CODEX_ANNOUNCER",
      "betaBuilds": "EZO_CODEX_BETA_BUILDS",
      "codexLog": "CODEX_LOG",
      "bugReports": "EZO_CODEX_BUG_REPORTS"
    }
  }
}
